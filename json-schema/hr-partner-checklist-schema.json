  "title": "Checklist",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "comments": { "type": "string" },
    "status": { "type": "string" },
    "assigned_at": { "type": "string", "format": "date-time" },
